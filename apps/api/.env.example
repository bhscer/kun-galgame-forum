# Server
SERVER_PORT=2334
SERVER_MODE=dev

# Database (same PostgreSQL used by Prisma)
KUN_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/kungalgame
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OAuth (KUN Galgame OAuth)
OAUTH_SERVER_URL=https://oauth.kungal.com/api/v1
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=https://www.kungal.com/auth/callback
JWT_SECRET=

# S3 image bed (small inline images, stickers — Cloudflare R2 in prod)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# File storage (toolset archive uploads — Backblaze B2 in prod).
# Separate from the image bed: B2 has the bucket-level CORS policy that
# lets the browser do presigned-PUT uploads directly. Leave empty to
# disable toolset uploads entirely.
FILE_STORAGE_ENDPOINT=
FILE_STORAGE_REGION=
FILE_STORAGE_BUCKET=
FILE_STORAGE_ACCESS_KEY=
FILE_STORAGE_SECRET_KEY=

# Mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=

# Search (Meilisearch)
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Galgame Wiki service (kungal proxies read/write here)
GALGAME_WIKI_BASE_URL=http://127.0.0.1:9280/api

# image_service — public CDN prefix used by the rewriteBanners walker
# to resolve effective_banner_hash / per-row image_hash into ready URLs.
# MUST match the wiki side's KUN_IMAGE_PUBLIC_BASE_URL exactly (no
# trailing slash).
KUN_IMAGE_PUBLIC_BASE_URL=https://image.kungal.iloveren.link

# image_service — client credentials for direct uploads from kungal
# (galgame covers / screenshots — U2). When empty, /image/galgame
# returns a clear "未配置" error instead of attempting an unauthorized
# upload. Set both ID and SECRET to enable the upload endpoint.
KUN_IMAGE_CLIENT_BASE_URL=http://127.0.0.1:9278
KUN_IMAGE_CLIENT_ID=
KUN_IMAGE_CLIENT_SECRET=
