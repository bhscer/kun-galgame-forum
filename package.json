{
  "name": "kun-galgame-forum",
  "version": "6.0.47",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -F \"./apps/**\" --parallel --stream run dev",
    "dev:web": "pnpm -F web run dev",
    "dev:api": "pnpm -F @apps/api run dev",
    "build": "pnpm run build:api && pnpm run build:web",
    "build:web": "pnpm -F web run build",
    "build:api": "pnpm -F @apps/api run build",
    "format": "pnpm -F \"./apps/**\" --parallel run format",
    "lint": "pnpm -F web run lint",
    "lint:fix": "pnpm -F web run lint:fix",
    "typecheck": "pnpm -F web run typecheck",
    "vet": "pnpm -F @apps/api run vet",
    "test:api": "pnpm -F @apps/api run test",
    "migrate": "pnpm -F @apps/api run migrate",
    "migrate:down": "pnpm -F @apps/api run migrate:down",
    "prepare": "husky",
    "precommit": "node .husky/scripts/bumpAppVersion.js && git add package.json",
    "prod:deploy": "./scripts/deploy.sh",
    "prod:start": "./scripts/start.sh",
    "prod:stop": "./scripts/stop.sh",
    "prod:restart": "./scripts/restart.sh",
    "prod:logs": "pm2 logs"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "esno": "^4.8.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.1"
  },
  "pnpm": {
    "overrides": {
      "@nuxt/schema": "4.4.7",
      "is-arguments": "npm:@nolyfill/is-arguments@^1",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "is-generator-function": "npm:@nolyfill/is-generator-function@^1",
      "is-typed-array": "npm:@nolyfill/is-typed-array@^1",
      "isarray": "npm:@nolyfill/isarray@^1",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1",
      "string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
      "which-typed-array": "npm:@nolyfill/which-typed-array@^1",
      "prosemirror-model": "1.25.3",
      "@milkdown/components": "7.17.3",
      "@milkdown/core": "7.17.3",
      "@milkdown/ctx": "7.17.3",
      "@milkdown/exception": "7.17.3",
      "@milkdown/kit": "7.17.3",
      "@milkdown/plugin-block": "7.17.3",
      "@milkdown/plugin-clipboard": "7.17.3",
      "@milkdown/plugin-cursor": "7.17.3",
      "@milkdown/plugin-history": "7.17.3",
      "@milkdown/plugin-indent": "7.17.3",
      "@milkdown/plugin-listener": "7.17.3",
      "@milkdown/plugin-slash": "7.17.3",
      "@milkdown/plugin-tooltip": "7.17.3",
      "@milkdown/plugin-trailing": "7.17.3",
      "@milkdown/plugin-upload": "7.17.3",
      "@milkdown/preset-commonmark": "7.17.3",
      "@milkdown/preset-gfm": "7.17.3",
      "@milkdown/prose": "7.17.3",
      "@milkdown/transformer": "7.17.3",
      "@milkdown/utils": "7.17.3",
      "vue-router": "5.0.4"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "aws-sdk",
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "puppeteer",
      "vue-demi"
    ]
  }
}
