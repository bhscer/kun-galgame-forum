# ── kungal web (apps/web, Nuxt 4 SSR) runtime env ──────────────────────────
# Copy to docker/web.env. These are Nuxt's canonical NUXT_* / NUXT_PUBLIC_*
# runtime overrides — they win over whatever was baked via build args, so you
# can build the image once and point it at any environment here.
#
# ⚠ The api URL is TWO different values in a container:
#   • NUXT_API_BASE_URL        — SSR (server) → reach the api over the internal
#                                docker network by SERVICE NAME (no host port).
#   • NUXT_PUBLIC_API_BASE_URL — browser → must be reachable from the user's
#                                machine (host port / public domain).
# Setting only API_BASE_URL (as in dev) makes SSR try the browser URL and fail.

NODE_ENV=production

# SSR-side (server → api over the internal network)
NUXT_API_BASE_URL=http://api:2334

# Browser-side public config
NUXT_PUBLIC_API_BASE_URL=http://localhost:12334
NUXT_PUBLIC_OAUTH_SERVER_URL=http://localhost:19277/api/v1
NUXT_PUBLIC_OAUTH_FRONTEND_URL=http://localhost:19420
NUXT_PUBLIC_OAUTH_CLIENT_ID=kungal-web
NUXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:17777/auth/callback
NUXT_PUBLIC_GALGAME_WIKI_URL=http://localhost:19280/api
NUXT_PUBLIC_KUN_GALGAME_URL=http://localhost:17777

# Optional
# NUXT_PUBLIC_KUN_VISUAL_NOVEL_FORUM_YANDEX_VERIFICATION=
