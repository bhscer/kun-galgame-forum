# ── kungal API (apps/api) runtime env ──────────────────────────────────────
# Copy to docker/api.env and fill the blanks. Read at RUNTIME via env_file;
# never baked into the image, never committed (docker/*.env is gitignored).
#
# Hostnames are CONTAINER service names, not host ports. They resolve on
# kun-galgame-infra's shared network (postgres / redis / oauth / image / wiki),
# which kungal's docker-compose.yml joins — so bring infra up first.

# Server
SERVER_PORT=2334
SERVER_MODE=prod

# Database — kungal's own DB (kungalgame) on infra's shared Postgres.
# Set the password to match infra's Postgres (local default 191007); real creds in prod.
KUN_DATABASE_URL=postgresql://postgres:kungal_dev_pw@postgres:5432/kungalgame
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OAuth (source of truth for identity + moemoepoint)
OAUTH_SERVER_URL=http://oauth:9277/api/v1
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://www.kungal.com/auth/callback
JWT_SECRET=

# S3 image bed (inline images, stickers — Cloudflare R2 in prod)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# File storage (toolset archive uploads — Backblaze B2 in prod). Leave empty
# to disable toolset uploads entirely.
FILE_STORAGE_ENDPOINT=
FILE_STORAGE_REGION=
FILE_STORAGE_BUCKET=
FILE_STORAGE_ACCESS_KEY=
FILE_STORAGE_SECRET_KEY=

# Mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=

# Search (Meilisearch)
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=

# Galgame Wiki service (kungal proxies read/write here)
GALGAME_WIKI_BASE_URL=http://galgame:9280/api

# image_service — public CDN prefix. MUST equal infra's KUN_IMAGE_PUBLIC_BASE_URL
# (the shared image_service domain), no trailing slash. NOT the legacy image bed.
KUN_IMAGE_PUBLIC_BASE_URL=https://image.kungal.iloveren.link

# image_service — client credentials for direct galgame-cover uploads. Set
# both to enable /image/galgame; leave empty for a clear "未配置" error.
KUN_IMAGE_CLIENT_BASE_URL=http://image:9278
KUN_IMAGE_CLIENT_ID=
KUN_IMAGE_CLIENT_SECRET=
